# ============================================================
# eCommerce Platform — Environment Variables
# ============================================================
# Copy this file to .env before running docker compose up.
# The defaults below work for local Docker development.
# Change JWT_SECRET and all passwords before deploying.
# ============================================================

# ------------------------------------------------------------
# MySQL Database
# ------------------------------------------------------------

# Root password for the MySQL container (used by healthcheck)
MYSQL_ROOT_PASSWORD=rootpassword

# Name of the application database (created automatically on first run)
MYSQL_DATABASE=ecommerce

# Application database user (less privileged than root)
MYSQL_USER=appuser

# Application database user password
MYSQL_PASSWORD=apppassword

# ------------------------------------------------------------
# Backend — JWT
# ------------------------------------------------------------

# Secret key used to sign and verify JSON Web Tokens.
# Must be a long, random string in production.
# Never commit a real secret to version control.
JWT_SECRET=changeme_in_production_use_a_long_random_string

# How long tokens remain valid. Examples: 7d, 24h, 1h
JWT_EXPIRES_IN=7d

# ------------------------------------------------------------
# Frontend — Vite build-time variables
# ------------------------------------------------------------

# Base URL for the API. Leave empty when running with Docker Compose
# because nginx proxies /api requests to the backend service.
# Set to http://localhost:4000 for local development without Docker.
VITE_API_URL=

# ------------------------------------------------------------
# Backend — CORS
# ------------------------------------------------------------

# Origin allowed to call the API.
# Docker default: http://localhost:3000 (nginx-served frontend).
# Local Vite dev (no Docker): set to http://localhost:5173.
CORS_ORIGIN=http://localhost:3000
